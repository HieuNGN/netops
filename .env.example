# NetOps Environment Configuration
# Copy this file to .env and customize for your environment

# SNMP Settings
SNMP_HOST=127.0.0.1
SNMP_COMMUNITY=public
SNMP_TIMEOUT=5
SNMP_RETRIES=3

# API Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# PostgreSQL Database Settings
# Option A: single connection URL (overrides POSTGRES_* below)
# DATABASE_URL=postgresql+asyncpg://netops:netops@localhost:5432/netops
# Option B: individual params (used when DATABASE_URL is not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=netops
POSTGRES_USER=netops
POSTGRES_PASSWORD=netops

# SQLite fallback (opt-in, zero-dependency dev — set to 1 to bypass PG)
# NETOPS_USE_SQLITE=1
# NETOPS_SQLITE_PATH=data/netops.db

# Authentication
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production
# Set NETOPS_COOKIE_SECURE=1 for HTTPS production
# NETOPS_COOKIE_SECURE=0

# Encryption at rest for SNMP credentials (optional)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NETOPS_ENCRYPTION_KEY=

# Frontend API URL (use /api for same-origin nginx proxy, or full URL for dev)
VITE_API_URL=/api

# Discovery
# NETOPS_AUTO_MIGRATE=1
# NETOPS_REQUIRE_MIGRATIONS=0
# NETOPS_AUTO_DISCOVER_MODE=merge
# NETOPS_NETWORK_CHECK_INTERVAL=60
# NETOPS_PHASE4_PARTITIONED_HISTORY=0

# Connection pool
# PG_POOL_MIN=4
# PG_POOL_MAX=25
# PG_COMMAND_TIMEOUT=60

# Optional: Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
