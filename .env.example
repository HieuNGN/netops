# NetOps Environment Configuration
# Copy this file to .env and customize for your environment

# SNMP Settings
SNMP_HOST=127.0.0.1
SNMP_COMMUNITY=public
SNMP_TIMEOUT=5
SNMP_RETRIES=3

# API Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# PostgreSQL Database Settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=netops
POSTGRES_USER=netops
POSTGRES_PASSWORD=netops

# Optional: Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
