# NetOps Environment Configuration
# Copy this file to .env and customize for your environment

# SNMP Settings
SNMP_HOST=127.0.0.1
SNMP_COMMUNITY=public
SNMP_TIMEOUT=5
SNMP_RETRIES=3

# API Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# PostgreSQL Database Settings
# These names match the docker-compose env vars and Python DB client.
# Option A: single connection URL (overrides POSTGRES_* below)
# DATABASE_URL=postgresql+asyncpg://netops:netops@localhost:5432/netops
# Option B: individual params (used when DATABASE_URL is not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=netops
POSTGRES_USER=netops
POSTGRES_PASSWORD=netops

# SQLite fallback (opt-in, zero-dependency dev — set to 1 to bypass PG)
# NETOPS_USE_SQLITE=1

# Authentication
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production

# Frontend API URL (use /api for same-origin nginx proxy, or full URL for dev)
VITE_API_URL=/api

# Optional: Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
