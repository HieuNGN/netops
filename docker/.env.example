# NetOps Docker Environment Variables
# Copy to .env in project root or docker/ directory and customize

# PostgreSQL
POSTGRES_DB=netops
POSTGRES_USER=netops
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=80

# SNMP Defaults
SNMP_HOST=127.0.0.1
SNMP_COMMUNITY=public
SNMP_TIMEOUT=5
SNMP_RETRIES=3

# Logging
LOG_LEVEL=INFO
