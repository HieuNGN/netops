# NetOps Docker Environment Variables
# Copy to .env in docker/ directory (or project root for compose --env-file) and customize

# PostgreSQL
POSTGRES_DB=netops
POSTGRES_USER=netops
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=80

# Auth (required — fail-fast on missing)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production

# Encryption at rest for SNMP credentials (optional but recommended)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NETOPS_ENCRYPTION_KEY=

# SNMP Defaults
SNMP_HOST=127.0.0.1
SNMP_COMMUNITY=public
SNMP_TIMEOUT=5
SNMP_RETRIES=3

# Discovery
# NETOPS_AUTO_DISCOVER_MODE=merge
# NETOPS_NETWORK_CHECK_INTERVAL=60

# Frontend API URL (default /api for nginx proxy)
VITE_API_URL=/api

# Logging
LOG_LEVEL=INFO
